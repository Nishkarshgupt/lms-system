<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Feedback</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Gilroy:wght@400;700&family=Juana:wght@400;700&display=swap');

        body {
            background: linear-gradient(to right, #0f0c29, #302b63, #24243e);
            color: white;
            font-family: 'Gilroy', sans-serif;
            transition: background 0.5s ease-in-out;
        }

        .footer {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 15px;
            color: white;
            text-align: center;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            position: fixed;
            bottom: 0;
            width: 100%;
        }

        .header {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 11px 30px 20px;
            color: white;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            font-family: 'Juana', serif;
            position: relative;
        }

        .header h1 {
            font-size: 2.6rem;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .header p {
            font-size: 1.2rem;
            margin-bottom: 20px;
            color: #d4d4d4;
        }

        .header nav {
            width: 60%;
        }

        .header .navbar-nav {
            display: flex;
            justify-content: center;
            width: 100%;
        }

        .header .navbar-nav .nav-item {
            padding: 10px 15px;
        }

        .header nav a {
            font-size: 1.1rem;
            font-weight: 600;
            color: white;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 5px;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .header nav a:hover {
            background-color: #ffffff33;
            color: #f9f9f9;
        }

        .header nav a.active {
            background-color: #ffffff66;
            color: #24243e;
            font-weight: 700;
        }

        .feedback-form {
            max-width: 800px;
            margin: 50px auto 127px;
            padding: 30px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
            backdrop-filter: blur(10px);
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            font-size: 1.1rem;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            font-size: 1rem;
            padding: 10px;
            width: 100%;
            border-radius: 8px;
            border: 1px solid #ccc;
            background-color: transparent;
            color: white;
        }

        .form-group button {
            padding: 10px 20px;
            font-size: 1.1rem;
            border-radius: 8px;
            background-color: #24cfa6;
            color: white;
            transition: background-color 0.3s ease;
        }

        .form-group button:hover {
            background-color: #1a9c7e;
        }

        .rating-label {
            margin-right: 10px;
        }

        .form-group textarea {
            height: 150px;
            resize: none;
            margin-bottom: 35px;
        }

        #setMargin{
            margin-top: 23px;
        }
        /* Smooth page transitions */
        body {
            animation: fadeIn 1s ease-in-out;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }
    </style>
</head>

<body>
    <!-- Header Section -->
    <header class="header d-flex justify-content-between align-items-center">
        <div>
            <h1>Welcome to the Student Panel</h1>
            <p>Provide your feedback about the university</p>
        </div>
        <nav class="navbar navbar-expand-lg navbar-light w-60">
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto w-100 text-center">
                    <li class="nav-item">
                        <a href="/student_panel" class="nav-link ">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a href="/profile" class="nav-link">Profile</a>
                    </li>
                    <li class="nav-item">
                        <a href="/course" class="nav-link">Courses</a>
                    </li>
                    <li class="nav-item">
                        <a href="/feedback" class="nav-link active">Feedback</a>
                    </li>
                    <li class="nav-item">
                        <a href="/logout" class="nav-link">Logout</a>
                    </li>
                </ul>
            </div>
        </nav>
    </header>

    <!-- Feedback Form Section -->
    <div class="feedback-form">
        <h2 class="text-center mb-4">Student Feedback Form</h2>

        <form>
            <div class="form-group">
                <label for="feedbackQuery">What problem are you facing at the university?</label>
                <textarea id="feedbackQuery" class="form-control" placeholder="Describe your issue..." required></textarea>
            </div>

            <div class="form-group">
                <label for="question1" class="d-block">How would you rate the teaching quality?</label>
                <div class="d-flex justify-content-start">
                    <label class="rating-label">1</label><input type="radio" name="question1" value="1" required>
                    <label class="rating-label">2</label><input type="radio" name="question1" value="2" required>
                    <label class="rating-label">3</label><input type="radio" name="question1" value="3" required>
                    <label class="rating-label">4</label><input type="radio" name="question1" value="4" required>
                    <label class="rating-label">5</label><input type="radio" name="question1" value="5" required>
                </div>
            </div>

            <div class="form-group">
                <label for="question2" class="d-block">How satisfied are you with the infrastructure?</label>
                <div class="d-flex justify-content-start">
                    <label class="rating-label">1</label><input type="radio" name="question2" value="1" required>
                    <label class="rating-label">2</label><input type="radio" name="question2" value="2" required>
                    <label class="rating-label">3</label><input type="radio" name="question2" value="3" required>
                    <label class="rating-label">4</label><input type="radio" name="question2" value="4" required>
                    <label class="rating-label">5</label><input type="radio" name="question2" value="5" required>
                </div>
            </div>

            <div class="form-group">
                <label for="question3" class="d-block">How would you rate the placement support?</label>
                <div class="d-flex justify-content-start">
                    <label class="rating-label">1</label><input type="radio" name="question3" value="1" required>
                    <label class="rating-label">2</label><input type="radio" name="question3" value="2" required>
                    <label class="rating-label">3</label><input type="radio" name="question3" value="3" required>
                    <label class="rating-label">4</label><input type="radio" name="question3" value="4" required>
                    <label class="rating-label">5</label><input type="radio" name="question3" value="5" required>
                </div>
            </div>

            <div class="form-group">
                <label for="question4" class="d-block">How satisfied are you with the faculty support?</label>
                <div class="d-flex justify-content-start">
                    <label class="rating-label">1</label><input type="radio" name="question4" value="1" required>
                    <label class="rating-label">2</label><input type="radio" name="question4" value="2" required>
                    <label class="rating-label">3</label><input type="radio" name="question4" value="3" required>
                    <label class="rating-label">4</label><input type="radio" name="question4" value="4" required>
                    <label class="rating-label">5</label><input type="radio" name="question4" value="5" required>
                </div>
            </div>

            <div class="form-group">
                <label for="question5" class="d-block">How likely are you to recommend this university to others?</label>
                <div class="d-flex justify-content-start">
                    <label class="rating-label">1</label><input type="radio" name="question5" value="1" required>
                    <label class="rating-label">2</label><input type="radio" name="question5" value="2" required>
                    <label class="rating-label">3</label><input type="radio" name="question5" value="3" required>
                    <label class="rating-label">4</label><input type="radio" name="question5" value="4" required>
                    <label class="rating-label">5</label><input type="radio" name="question5" value="5" required>
                </div>
            </div>

            <div class="form-group">
                <label for="recommendation" id="setMargin">Your Recommendations (Optional)</label>
                <textarea id="recommendation" class="form-control" placeholder="Enter your suggestions here..." rows="4"></textarea>
            </div>

            <div class="form-group">
                <button type="submit"onclick="alert('Your feedback successfully saved!'); " class="btn btn-primary w-100">Submit Feedback</button>
            </div>
        </form>
    </div>

    <!-- Footer Section -->
    <footer class="footer">
        <p>&copy; 2025 Institute ERP System. All rights reserved.</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
