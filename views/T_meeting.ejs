<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teacher-Student Meeting</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Gilroy:wght@400;700&family=Juana:wght@400;700&display=swap');

        body {
            background: linear-gradient(to right, #0f0c29, #302b63, #24243e);
            color: white;
            font-family: 'Gilroy', sans-serif;
            transition: background 0.5s ease-in-out;
        }

        .footer {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 15px;
            color: white;
            text-align: center;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            position: fixed;
            bottom: 0;
            width: 100%;
        }

        .header {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 11px 30px 20px;
            color: white;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            font-family: 'Juana', serif;
            position: relative;
        }

        .header h1 {
            font-size: 2.6rem;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .header p {
            font-size: 1.2rem;
            margin-bottom: 20px;
            color: #d4d4d4;
        }

        .header nav {
            width: 100%;
        }

        .header .navbar-nav {
            display: flex;
            justify-content: center;
            width: 100%;
        }

        .header .navbar-nav .nav-item {
            padding: 10px 15px;
        }

        .header nav a {
            font-size: 1.1rem;
            font-weight: 600;
            color: white;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 5px;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .header nav a:hover {
            background-color: #ffffff33;
            color: #f9f9f9;
        }

        .header nav a.active {
            background-color: #ffffff66;
            color: #24243e;
            font-weight: 700;
        }

        .btn {
            padding: 10px 20px;
            font-size: 1.1rem;
            border-radius: 8px;
            background-color: #24cfa6;
            color: white;
            transition: background-color 0.3s ease;
        }

        .btn:hover {
            background-color: #1a9c7e;
        }

        .meeting-container {
            max-width: 1000px;
            margin: 50px auto;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
            backdrop-filter: blur(10px);
        }

        .meeting-container h2 {
            text-align: center;
            margin-bottom: 30px;
        }

        .meeting-card {
            background-color: #1e1e2f;
            margin: 15px 0;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.3);
            transition: transform 0.3s ease-in-out, box-shadow 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .meeting-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        }

        .meeting-card .info {
            flex-grow: 1;
        }

        .meeting-card h5 {
            font-size: 1.6rem;
            margin-bottom: 10px;
        }

        .meeting-card p {
            font-size: 1.2rem;
        }

        .meeting-card .btn-message {
            margin-top: 10px;
        }

        .meeting-buttons {
            display: flex;
            justify-content: space-between;
            margin-top: 30px;
        }

        .meeting-buttons button {
            width: 48%;
        }

        .chat-container {
            margin-top: 30px;
            display: flex;
            flex-direction: column;
            max-height: 300px;
            overflow-y: scroll;
            background-color: #2a2a3b;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.3);
        }

        .chat-message {
            margin-bottom: 10px;
            padding: 10px;
            background-color: #353545;
            border-radius: 8px;
            max-width: 70%;
            align-self: flex-start;
            font-size: 1rem;
            color: white;
        }

        .chat-message.student {
            align-self: flex-end;
            background-color: #24cfa6;
        }

        .input-message {
            display: flex;
            margin-top: 15px;
        }

        .input-message input {
            width: 90%;
            padding: 10px;
            border-radius: 8px;
            border: none;
            background-color: #353545;
            color: white;
            font-size: 1rem;
        }

        .input-message button {
            width: 10%;
            background-color: #24cfa6;
            border: none;
            border-radius: 8px;
            color: white;
            font-size: 1.2rem;
            cursor: pointer;
        }

        .input-message button:hover {
            background-color: #1a9c7e;
        }
    </style>
</head>

<body>
    <!-- Header Section -->
    <header class="header d-flex justify-content-between align-items-center">
        <div>
            <h1>Welcome to the Teacher Panel</h1>
            <p>Your Meeting Room</p>
        </div>
        <nav class="navbar navbar-expand-lg navbar-light w-100">
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto w-100 text-center">
                    <li class="nav-item">
                        <a href="/teacher_panel" class="nav-link">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a href="/T_profile" class="nav-link">Profile</a>
                    </li>
                   
                    <li class="nav-item">
                        <a href="/T_attendance" class="nav-link">Attendance</a>
                    </li>
                    <li class="nav-item">
                        <a href="/logout" class="nav-link">Logout</a>
                    </li>
                </ul>
            </div>
        </nav>
    </header>

    <!-- Main Section (Teacher-Student Meeting) -->
    <div class="meeting-container">
        <h2>Teacher's Meeting Room</h2>

        <!-- List of Students in the Meeting -->
        <div class="meeting-card">
            <div class="info">
                <h5>Student: Rahul Kumar</h5>
                <p>Status: Connected</p>
            </div>
            <button class="btn btn-message" onclick="sendMessage('Rahul Kumar')">Send Message</button>
        </div>

        <div class="meeting-card">
            <div class="info">
                <h5>Student: Priya Sharma</h5>
                <p>Status: Connected</p>
            </div>
            <button class="btn btn-message" onclick="sendMessage('Priya Sharma')">Send Message</button>
        </div>

        <div class="meeting-card">
            <div class="info">
                <h5>Student: Anil Kumar</h5>
                <p>Status: Connected</p>
            </div>
            <button class="btn btn-message" onclick="sendMessage('Anil Kumar')">Send Message</button>
        </div>

        <div class="meeting-card">
            <div class="info">
                <h5>Student: Deepika Rani</h5>
                <p>Status: Connected</p>
            </div>
            <button class="btn btn-message" onclick="sendMessage('Deepika Rani')">Send Message</button>
        </div>

        <div class="meeting-card">
            <div class="info">
                <h5>Student: Rohan Verma</h5>
                <p>Status: Connected</p>
            </div>
            <button class="btn btn-message" onclick="sendMessage('Rohan Verma')">Send Message</button>
        </div>

        <!-- Meeting Start and End buttons -->
        <div class="meeting-buttons">
            <button class="btn btn-primary" onclick="startMeeting()">Start Meeting</button>
            <button class="btn btn-danger" onclick="endMeeting()">End Meeting</button>
        </div>

        <!-- Chat Container -->
        <div class="chat-container" id="chatContainer">
            <!-- Chat messages will appear here -->
        </div>

        <!-- Input for Sending Messages -->
        <div class="input-message">
            <input type="text" id="messageInput" placeholder="Type a message">
            <button onclick="sendChatMessage()">Send</button>
        </div>
    </div>

    <!-- Footer Section -->
    <footer class="footer">
        <p>&copy; 2025 Institute ERP System. All rights reserved.</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Function to simulate sending a message
        function sendMessage(studentName) {
            alert('Message sent to ' + studentName);
        }

        // Function to start the meeting
        function startMeeting() {
            alert('Meeting started');
        }

        // Function to end the meeting
        function endMeeting() {
            alert('Meeting ended');
        }

        // Function to send a chat message
        function sendChatMessage() {
            let message = document.getElementById("messageInput").value;
            if (message.trim()) {
                let chatContainer = document.getElementById("chatContainer");

                // Create a new chat message
                let messageElement = document.createElement("div");
                messageElement.classList.add("chat-message", "student");
                messageElement.textContent = message;

                // Append message to chat container
                chatContainer.appendChild(messageElement);

                // Clear input field
                document.getElementById("messageInput").value = "";
                chatContainer.scrollTop = chatContainer.scrollHeight; // Scroll to bottom
            }
        }
    </script>
</body>

</html>
