<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LMS - Student Panel</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Gilroy:wght@400;700&family=Juana:wght@400;700&display=swap');

        body {
            background: linear-gradient(to right, #0f0c29, #302b63, #24243e);
            color: white;
            font-family: 'Gilroy', sans-serif;
            transition: background 0.5s ease-in-out;
        }

        .footer {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 15px;
            color: white;
            text-align: center;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            position: fixed;
            bottom: 0;
            width: 100%;
        }

        .header {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 11px 30px 20px;
            color: white;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            font-family: 'Juana', serif;
            position: relative;
        }

        .header h1 {
            font-size: 2.6rem;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .header p {
            font-size: 1.2rem;
            margin-bottom: 20px;
            color: #d4d4d4;
        }

        .header nav {
            width: 60%;
        }

        .header .navbar-nav {
            display: flex;
            justify-content: center;
            width: 100%;
        }

        .header .navbar-nav .nav-item {
            padding: 10px 15px;
        }

        .header nav a {
            font-size: 1.1rem;
            font-weight: 600;
            color: white;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 5px;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .header nav a:hover {
            background-color: #ffffff33;
            color: #f9f9f9;
        }

        .header nav a.active {
            background-color: #ffffff66;
            color: #24243e;
            font-weight: 700;
        }

        .lms-section {
            max-width: 1200px;
            margin: 50px auto 127px;
            padding: 30px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
            backdrop-filter: blur(10px);
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 30px;
        }

        .card {
            background-color: rgba(0, 0, 0, 0.15);
            border-radius: 10px;
            padding: 20px;
            transition: transform 0.3s ease-in-out, box-shadow 0.3s ease;
            cursor: pointer;
        }

        .card:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
        }

        .card .card-title {
            font-size: 1.6rem;
            font-weight: bold;
        }

        .card .card-body {
            font-size: 1.2rem;
            color: #d4d4d4;
        }

        .card-icon {
            font-size: 2.5rem;
            color: #24cfa6;
            margin-bottom: 15px;
        }

        /* Smooth page transitions */
        body {
            animation: fadeIn 1s ease-in-out;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

    </style>
</head>

<body>
    <!-- Header Section -->
    <header class="header d-flex justify-content-between align-items-center">
        <div>
            <h1>Welcome to the LMS</h1>
            <p>Your Learning Management System</p>
        </div>
        <nav class="navbar navbar-expand-lg navbar-light w-60">
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto w-100 text-center">
                    <li class="nav-item">
                        <a href="/student_panel" class="nav-link">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a href="/profile" class="nav-link">Profile</a>
                    </li>
                    <li class="nav-item">
                        <a href="/course" class="nav-link">Courses</a>
                    </li>
                    
                    <li class="nav-item">
                        <a href="/lms" class="nav-link active">LMS</a>
                    </li>
                    <li class="nav-item">
                        <a href="/logout" class="nav-link">Logout</a>
                    </li>
                </ul>
            </div>
        </nav>
    </header>

    <!-- LMS Information Section -->
    <div class="lms-section">
        <!-- Course Card -->
        <div class="card" onclick="window.location.href='/project/frontend/student_features/course.html'">
            <div class="card-icon">
                <i class="fas fa-book"></i>
            </div>
            <div class="card-title">Courses</div>
            <div class="card-body">View your enrolled courses and materials.</div>
        </div>

        <!-- Attendance Card -->
        <div class="card" onclick="window.location.href='/project/frontend/student_features/attendance.html'">
            <div class="card-icon">
                <i class="fas fa-calendar-check"></i>
            </div>
            <div class="card-title">Attendance</div>
            <div class="card-body">Check your attendance records for all courses.</div>
        </div>

        <!-- Timetable Card -->
        <div class="card" onclick="window.location.href='/project/frontend/student_features/timetable.html'">
            <div class="card-icon">
                <i class="fas fa-clock"></i>
            </div>
            <div class="card-title">Timetable</div>
            <div class="card-body">View your class timetable for the current semester.</div>
        </div>

        <!-- College Info Card -->
        <div class="card" onclick="window.location.href='/project/frontend/student_features/college_info.html'">
            <div class="card-icon">
                <i class="fas fa-university"></i>
            </div>
            <div class="card-title">College Info</div>
            <div class="card-body">Get information about your college and facilities.</div>
        </div>

        <!-- Assignments Card -->
        <div class="card" onclick="window.location.href='/project/frontend/student_features/assignments.html';">
            <div class="card-icon">
                <i class="fas fa-tasks"></i>
            </div>
            <div class="card-title">Assignments</div>
            <div class="card-body">View your assignments, deadlines, and grades.</div>
               </div>
    </div>

    <!-- Footer Section -->
    <footer class="footer">
        <p>&copy; 2025 Institute ERP System. All rights reserved.</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    

</body>

</html>
