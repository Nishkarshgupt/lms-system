<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teacher Video Call - Student Panel</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Gilroy:wght@400;700&family=Juana:wght@400;700&display=swap');

        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            background: linear-gradient(to right, #0f0c29, #302b63, #24243e);
            color: white;
            font-family: 'Gilroy', sans-serif;
        }

        .footer {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 15px;
            color: white;
            text-align: center;
            position: fixed;
            bottom: 0;
            width: 100%;
        }

        .header {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 11px 30px 20px;
            color: white;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            font-family: 'Juana', serif;
            position: relative;
        }

        .header h1 {
            font-size: 2.6rem;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .header p {
            font-size: 1.2rem;
            margin-bottom: 20px;
            color: #d4d4d4;
        }

        .header nav {
            width: 60%;
        }

        .header .navbar-nav {
            display: flex;
            justify-content: center;
            width: 100%;
        }

        .header .navbar-nav .nav-item {
            padding: 10px 15px;
        }

        .header nav a {
            font-size: 1.1rem;
            font-weight: 600;
            color: white;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 5px;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .header nav a:hover {
            background-color: #ffffff33;
            color: #f9f9f9;
        }

        .header nav a.active {
            background-color: #ffffff66;
            color: #24243e;
            font-weight: 700;
        }


        .teacher-cards {
            margin: 40px auto 80px;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
        }

        .card-teacher {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            padding: 20px;
            display: flex;
            align-items: center;
            gap: 20px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
            transition: transform 0.3s, box-shadow 0.3s;
            backdrop-filter: blur(10px);
        }

        .card-teacher:hover {
            transform: scale(1.05);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.4);
        }

        .card-teacher img {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            border: 3px solid #24cfa6;
            object-fit: cover;
        }

        .teacher-details {
            flex-grow: 1;
        }

        .teacher-details h4 {
            font-size: 1.5rem;
            font-weight: bold;
            margin-bottom: 5px;
        }

        .teacher-details h6 {
            font-size: 1rem;
            color: #d4d4d4;
            margin-bottom: 5px;
        }

        .teacher-details p {
            font-size: 0.9rem;
            color: #ffffffcc;
            margin-bottom: 15px;
        }

        .btn-view-profile {
            background-color: #24cfa6;
            color: white;
            border: none;
            padding: 10px 20px;
            font-weight: bold;
            border-radius: 5px;
            text-decoration: none;
            transition: background-color 0.3s ease;
        }

        .btn-view-profile:hover {
            background-color: #20b492;
            text-decoration: none;
        }
    </style>
</head>

<body>
    <!-- Header Section -->
    <header class="header d-flex justify-content-between align-items-center">
        <div>
            <h1>Welcome to the Student Panel</h1>
            <p>Video Call with Teachers</p>
        </div>
        <nav class="navbar navbar-expand-lg navbar-light w-60">
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto w-100 text-center">
                    <li class="nav-item">
                        <a href="/student_panel" class="nav-link">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a href="/profile" class="nav-link">Profile</a>
                    </li>
                    <li class="nav-item">
                        <a href="/course" class="nav-link">Courses</a>
                    </li>
                    <li class="nav-item">
                        <a href="/feedback" class="nav-link">Feedback</a>
                    </li>
                    <li class="nav-item">
                        <a href="/logout" class="nav-link">Logout</a>
                    </li>
                </ul>
            </div>
        </nav>
    </header>

    <!-- Main Section -->
    <div class="container">
        <div class="teacher-cards">
            <!-- Teacher 1 -->
            <div class="card-teacher">
                <img src="teacher1.jpg" alt="Teacher 1">
                <div class="teacher-details">
                    <h4>Mr. Manikandan Sir</h4>
                    <h6>Ph.D. in Mathematics</h6>
                    <p>Phone: +91 9876543210<br>Email: sunil.sharma@institute.edu</p>
                    <a href="teacher1_video_call.html" class="btn-view-profile">View Profile</a>
                </div>
            </div>
            <!-- Teacher 2 -->
            <div class="card-teacher">
                <img src="teacher2.jpg" alt="Teacher 2">
                <div class="teacher-details">
                    <h4>Mr. Manish Kumar Maurya</h4>
                    <h6>M.Sc. in Physics</h6>
                    <p>Phone: +91 9876543221<br>Email: aarti.patel@institute.edu</p>
                    <a href="teacher2_video_call.html" class="btn-view-profile">View Profile</a>
                </div>
            </div>
            <!-- Teacher 3 -->
            <div class="card-teacher">
                <img src="teacher3.jpg" alt="Teacher 3">
                <div class="teacher-details">
                    <h4>Ms. Soni Chaurasiya</h4>
                    <h6>M.Tech in Computer Science</h6>
                    <p>Phone: +91 9876543232<br>Email: rajesh.gupta@institute.edu</p>
                    <a href="teacher3_video_call.html" class="btn-view-profile">View Profile</a>
                </div>
            </div>
            <!-- Teacher 4 -->
            <div class="card-teacher">
                <img src="teacher4.jpg" alt="Teacher 4">
                <div class="teacher-details">
                    <h4>Ms. Sneha Das</h4>
                    <h6>M.A. in English Literature</h6>
                    <p>Phone: +91 9876543243<br>Email: sneha.das@institute.edu</p>
                    <a href="teacher4_video_call.html" class="btn-view-profile">View Profile</a>
                </div>
            </div>
            <!-- Teacher 5 -->
            <div class="card-teacher">
                <img src="teacher5.jpg" alt="Teacher 5">
                <div class="teacher-details">
                    <h4>Dr. Anil Verma</h4>
                    <h6>Ph.D. in Chemistry</h6>
                    <p>Phone: +91 9876543254<br>Email: anil.verma@institute.edu</p>
                    <a href="teacher5_video_call.html" class="btn-view-profile">View Profile</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer Section -->
    <footer class="footer">
        <p>&copy; 2025 Institute ERP System. All rights reserved.</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
