<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chatbot - Student Panel</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Gilroy:wght@400;700&family=Juana:wght@400;700&display=swap');

        body {
            background: linear-gradient(to right, #0f0c29, #302b63, #24243e);
            color: white;
            font-family: 'Gilroy', sans-serif;
        }

        .footer {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 15px;
            color: white;
            text-align: center;
            position: fixed;
            bottom: 0;
            width: 100%;
        }

        .header {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 11px 30px 20px;
            color: white;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            font-family: 'Juana', serif;
            position: relative;
        }

        .header h1 {
            font-size: 2.6rem;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .header p {
            font-size: 1.2rem;
            margin-bottom: 20px;
            color: #d4d4d4;
        }

        .header nav {
            width: 60%;
        }

        .header .navbar-nav {
            display: flex;
            justify-content: center;
            width: 100%;
        }

        .header .navbar-nav .nav-item {
            padding: 10px 15px;
        }

        .header nav a {
            font-size: 1.1rem;
            font-weight: 600;
            color: white;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 5px;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .header nav a:hover {
            background-color: #ffffff33;
            color: #f9f9f9;
        }

        .header nav a.active {
            background-color: #ffffff66;
            color: #24243e;
            font-weight: 700;
        }

        .chat-section {
            margin: 40px auto;
            max-width: 800px;
            padding: 20px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(10px);
            height: 500px;
            overflow-y: auto;
        }

        .chatbox {
            background: rgba(0, 0, 0, 0.5);
            color: white;
            padding: 20px;
            border-radius: 8px;
            height: 80%;
            overflow-y: scroll;
            margin-bottom: 20px;
            animation: fadeIn 1s ease-out;
        }

        .message {
            margin-bottom: 20px;
        }

        .message.bot {
            text-align: left;
            animation: botMessageAnimation 0.5s ease-out;
        }

        .message.student {
            text-align: right;
            animation: studentMessageAnimation 0.5s ease-out;
        }

        .message p {
            background-color: #24cfa6;
            padding: 10px;
            border-radius: 10px;
            display: inline-block;
            max-width: 70%;
        }

        .message.student p {
            background-color: #302b63;
        }

        .input-box {
            display: flex;
            gap: 10px;
            animation: fadeIn 1s ease-out;
        }

        .input-box input {
            width: 80%;
            padding: 12px;
            border-radius: 8px;
            border: 1px solid #ccc;
            background-color: transparent;
            color: white;
            font-size: 1rem;
        }

        .input-box button {
            padding: 12px 20px;
            border-radius: 8px;
            background-color: #24cfa6;
            color: white;
            border: none;
            cursor: pointer;
            font-size: 1rem;
            animation: buttonAnimation 0.5s ease-out;
        }

        .input-box button:hover {
            background-color: #20b492;
        }

        .message.bot .icon,
        .message.student .icon {
            font-size: 1.5rem;
            margin-right: 10px;
            color: #24cfa6;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        @keyframes botMessageAnimation {
            from {
                transform: translateX(-50%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        @keyframes studentMessageAnimation {
            from {
                transform: translateX(50%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        @keyframes buttonAnimation {
            from {
                transform: scale(0.95);
                opacity: 0;
            }

            to {
                transform: scale(1);
                opacity: 1;
            }
        }
    </style>
</head>

<body>
    <!-- Header Section -->
    <header class="header d-flex justify-content-between align-items-center">
        <div>
            <h1>Welcome to the Student Panel</h1>
            <p>Chatbot</p>
        </div>
        <nav class="navbar navbar-expand-lg navbar-light w-60">
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto w-100 text-center">
                    <li class="nav-item">
                        <a href="/student_panel" class="nav-link">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a href="/profile" class="nav-link">Profile</a>
                    </li>
                    <li class="nav-item">
                        <a href="/course" class="nav-link">Courses</a>
                    </li>
                    <li class="nav-item">
                        <a href="/feedback" class="nav-link">Feedback</a>
                    </li>
                    <li class="nav-item">
                        <a href="/logout" class="nav-link">Logout</a>
                    </li>
                </ul>
            </div>
        </nav>
    </header>

    <!-- Main Section -->
    <div class="container">
        <div class="chat-section">
            <div class="chatbox" id="chatbox">
                <div class="message bot">
                    <i class="fas fa-robot icon"></i>
                    <p>Hello, I am your chatbot! How can I assist you today?</p>
                </div>
            </div>

            <div class="input-box">
                <input type="text" id="userMessage" placeholder="Type your message..."
                    onkeydown="if(event.key === 'Enter'){sendMessage();}">
                <button onclick="sendMessage()"><i class="fas fa-paper-plane"></i> Send</button>
            </div>
        </div>
    </div>

    <!-- Footer Section -->
    <footer class="footer">
        <p>&copy; 2025 Institute ERP System. All rights reserved.</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Chatbot Script -->
    <script>

        function sendMessage() {
            const userMessage = document.getElementById('userMessage').value;
            if (userMessage.trim() === "") return;

            // Add the user's message to the chatbox
            const chatbox = document.getElementById('chatbox');
            const userMessageElement = document.createElement('div');
            userMessageElement.classList.add('message', 'student');
            userMessageElement.innerHTML = `<i class="fas fa-user icon"></i><p>${userMessage}</p>`;
            chatbox.appendChild(userMessageElement);

            // Clear input field
            document.getElementById('userMessage').value = "";

            // Scroll to the bottom of the chatbox
            chatbox.scrollTop = chatbox.scrollHeight;

            // Simulate chatbot response after a delay
            setTimeout(() => {
                const botMessageElement = document.createElement('div');
                botMessageElement.classList.add('message', 'bot');

                // Predefined responses
                let botResponse = "Sorry, I didn't understand that. Anything Else";
                if (userMessage.toLowerCase().includes("fees")) {
                    botResponse = "You can check your fees in the 'Fees' section of the Student Panel.";
                }
                else if (userMessage.toLowerCase().includes("hi")) {
                    botResponse = "Hi! how can i help you?"
                }
                else if (userMessage.toLowerCase().includes("admit card")) {
                    botResponse = "To view your Admit card, go to the 'Admit card' section on the dashboard.";
                }
                else if (userMessage.toLowerCase().includes("where i found library books?")) {
                    botResponse = "To view  Library books, go to the 'library books' section on the dashboard And issue the books.";
                }
                // else if (userMessage.toLowerCase().includes("How can I see my examination sitting plan")) {
                //     botResponse = "To view your examination Sitting plan, go to the 'Examination sitting plan' section on the dashboard.";
                // }
                else if (userMessage.toLowerCase().includes("courses")) {
                    botResponse = "To view your courses, go to the 'Courses' section on the dashboard.";
                }

                botMessageElement.innerHTML = `<i class="fas fa-robot icon"></i><p>${botResponse}</p>`;
                chatbox.appendChild(botMessageElement);

                // Scroll to the bottom of the chatbox
                chatbox.scrollTop = chatbox.scrollHeight;
            }, 1000);

        }
    </script>


<script>
    function sendMessage() {
        const userMessage = document.getElementById('userMessage').value;
        if (userMessage.trim() === "") return;

        // Add the user's message to the chatbox
        const chatbox = document.getElementById('chatbox');
        const userMessageElement = document.createElement('div');
        userMessageElement.classList.add('message', 'student');
        userMessageElement.innerHTML = `<i class="fas fa-user icon"></i><p>${userMessage}</p>`;
        chatbox.appendChild(userMessageElement);

        // Clear input field
        document.getElementById('userMessage').value = "";

        // Scroll to the bottom of the chatbox
        chatbox.scrollTop = chatbox.scrollHeight;

        // Simulate chatbot response after a delay
        setTimeout(() => {
            const botMessageElement = document.createElement('div');
            botMessageElement.classList.add('message', 'bot');

            // Predefined responses with more logic for handling different queries
            let botResponse = getBotResponse(userMessage);

            botMessageElement.innerHTML = `<i class="fas fa-robot icon"></i><p>${botResponse}</p>`;
            chatbox.appendChild(botMessageElement);

            // Scroll to the bottom of the chatbox
            chatbox.scrollTop = chatbox.scrollHeight;
        }, 1000);
    }

    function getBotResponse(userMessage) {
        // Default response
        let response = "Sorry, I didn't understand that. Can you please ask something else?";

        // Make the user message lowercase for better matching
        const message = userMessage.toLowerCase();

        // Define response for common queries
        if (message.includes("hi") || message.includes("hello")) {
            response = "Hi there! How can I assist you today?";
        } else if (message.includes("fees")) {
            response = "You can check your fee status in the 'Fees' section of the Student Panel.";
        } else if (message.includes("admit card")) {
            response = "To view your Admit card, go to the 'Admit card' section on the dashboard.";
        } else if (message.includes("library books") || message.includes("library")) {
            response = "You can view library books in the 'Library' section on the dashboard and issue them from there.";
        } else if (message.includes("courses")) {
            response = "To view your enrolled courses, visit the 'Courses' section in your Student Panel.";
        } else if (message.includes("exam dates") || message.includes("exams")) {
            response = "To check your exam dates, visit the 'Examination' section in your dashboard.";
        } else if (message.includes("sitting plan") || message.includes("examination sitting plan")) {
            response = "You can view your examination sitting plan in the 'Examination Sitting Plan' section.";
        } else if (message.includes("profile")) {
            response = "To view and edit your profile, go to the 'Profile' section.";
        } else if (message.includes("timetable")) {
            response = "You can check your timetable in the 'Timetable' section.";
        } else if (message.includes("feedback")) {
            response = "To provide feedback, visit the 'Feedback' section on your Student Panel.";
        } else if (message.includes("logout")) {
            response = "You can log out by clicking the 'Logout' button on the top-right corner.";
        }

        return response;
    }
</script>


</body>

</html>