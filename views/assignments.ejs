<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Student Assignment Portal</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
     @import url('https://fonts.googleapis.com/css2?family=Gilroy:wght@400;700&family=Juana:wght@400;700&display=swap');
     
  </style>
</head>
<body>
  <div class="container mt-5">
    <h1 class="text-center mb-4">Student Assignment Portal</h1>

    <!-- Assignment List Section -->
    <div class="card">
      <div class="card-header">
        <h3>Available Assignments</h3>
      </div>
      <div class="card-body">
        <table class="table">
          <thead>
            <tr>
              <th>#</th>
              <th>Title</th>
              <th>Description</th>
              <th>Deadline</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="assignmentTable">
            <!-- Dynamic rows will be added here using JavaScript -->
          </tbody>
        </table>
      </div>
    </div>

    <!-- Submit Assignment Section -->
    <div class="card mt-4">
      <div class="card-header">
        <h3>Submit Assignment</h3>
      </div>
      <div class="card-body">
        <form id="submitForm">
          <div class="mb-3">
            <label for="assignmentId" class="form-label">Assignment ID</label>
            <input type="text" id="assignmentId" class="form-control" placeholder="Enter Assignment ID" required>
          </div>
          <div class="mb-3">
            <label for="studentFile" class="form-label">Upload File</label>
            <input type="file" id="studentFile" class="form-control" required>
          </div>
          <button type="submit" class="btn btn-success">Submit Assignment</button>
        </form>
      </div>
    </div>
  </div>

  <script>
    // Example assignment data
const assignments = [
  {
    id: 1,
    title: "Math Assignment 1",
    description: "Solve all exercises from Chapter 3.",
    deadline: "2025-01-30",
  },
  {
    id: 2,
    title: "Science Project",
    description: "Prepare a model of the solar system.",
    deadline: "2025-02-05",
  },
];

// Populate Assignments Table
function updateAssignmentTable() {
  const tableBody = document.getElementById("assignmentTable");
  tableBody.innerHTML = "";
  assignments.forEach((assignment) => {
    const row = `
      <tr>
        <td>${assignment.id}</td>
        <td>${assignment.title}</td>
        <td>${assignment.description}</td>
        <td>${assignment.deadline}</td>
        <td>
          <button class="btn btn-primary btn-sm">Download</button>
        </td>
      </tr>
    `;
    tableBody.innerHTML += row;
  });
}

// Handle Assignment Submission
document.getElementById("submitForm").addEventListener("submit", (e) => {
  e.preventDefault();

  const assignmentId = document.getElementById("assignmentId").value;
  const studentFile = document.getElementById("studentFile").files[0];

  if (!assignmentId || !studentFile) {
    alert("Please fill in all fields!");
    return;
  }

  alert(`Assignment ID ${assignmentId} submitted successfully!`);
  e.target.reset();
});

// Initialize Table
updateAssignmentTable();

  </script>
</body>
</html>
