<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Profile</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Gilroy:wght@400;700&family=Juana:wght@400;700&display=swap');

        body {
            background: linear-gradient(to right, #0f0c29, #302b63, #24243e);
            color: white;
            font-family: 'Gilroy', sans-serif;
            transition: background 0.5s ease-in-out;
        }

        .footer {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 15px;
            color: white;
            text-align: center;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        .header {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 11px 30px 20px;
            color: white;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            font-family: 'Juana', serif;
            position: relative;
        }

        .header h1 {
            font-size: 2.6rem;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .header p {
            font-size: 1.2rem;
            margin-bottom: 20px;
            color: #d4d4d4;
        }

        .header nav {
            width: 60%;
        }

        .header .navbar-nav {
            display: flex;
            justify-content: center;
            width: 100%;
        }

        .header .navbar-nav .nav-item {
            padding: 10px 15px;
        }

        .header nav a {
            font-size: 1.1rem;
            font-weight: 600;
            color: white;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 5px;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .header nav a:hover {
            background-color: #ffffff33;
            color: #f9f9f9;
        }

        .header nav a.active {
            background-color: #ffffff66;
            color: #24243e;
            font-weight: 700;
        }

        .profile-container {
            max-width: 1200px;
            margin: 50px auto;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
            backdrop-filter: blur(10px);
        }

        .profile-header {
            text-align: left;
            margin-bottom: 30px;
        }

        .profile-header h2 {
            font-size: 2rem;
            font-weight: bold;
            color: #f4f4f4;
        }

        .profile-header p {
            color: #ccc;
        }

        .profile-header .profile-img-container {
            position: relative;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .profile-header img {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid #24cfa6;
        }

        .profile-header .profile-img-container button {
            position: absolute;
            bottom: 10px;
            left: 50%;
            transform: translateX(-50%);
            background-color: #24cfa6;
            color: white;
            border: none;
            padding: 5px 15px;
            font-size: 0.9rem;
            border-radius: 5px;
        }

        .profile-info {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            gap: 20px;
        }

        .profile-info .info-box {
            background: #1f1f2d;
            border-radius: 10px;
            padding: 20px;
            width: 48%;
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .profile-info .info-box:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }

        .info-box h5 {
            font-size: 1.5rem;
            font-weight: bold;
            margin-bottom: 10px;
            color: #24cfa6;
        }

        .info-box p {
            font-size: 1.1rem;
            color: #ccc;
        }

        .info-box .info-title {
            font-weight: bold;
        }

        .btn {
            padding: 10px 20px;
            font-size: 1.1rem;
            border-radius: 8px;
            background-color: #24cfa6;
            color: white;
            transition: background-color 0.3s ease;
        }

        .btn:hover {
            background-color: #1a9c7e;
        }

        @media (max-width: 768px) {
            .profile-info {
                flex-direction: column;
            }

            .profile-info .info-box {
                width: 100%;
            }
        }
    </style>
</head>

<body>
    <!-- Header Section -->
    <header class="header d-flex justify-content-between align-items-center">
        <div>
            <h1>Welcome to the Student Panel</h1>
            <p>Manage your academic activities</p>
        </div>
        <nav class="navbar navbar-expand-lg navbar-light w-100">
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto w-100 text-center">
                    <li class="nav-item">
                        <a href="/teacher_panel" class="nav-link">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link active">Profile</a>
                    </li>
                    
                    <li class="nav-item">
                        <a href="/T_notification" class="nav-link">Notifications</a>
                    </li>
                    <li class="nav-item">
                        <a href="/logout" class="nav-link">Logout</a>
                    </li>
                </ul>
            </div>
        </nav>
        <div class="d-flex align-items-end justify-content-end">
            <!-- Profile Dropdown -->
            <div class="dropdown me-3">
                <button class="btn btn-outline-light dropdown-toggle" type="button" id="profileDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="fas fa-user"></i> Profile
                </button>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="profileDropdown">
                    <li><span class="dropdown-item">Name: Manikandan Sir</span></li>
                    <li><span class="dropdown-item">Teacher Id: 12345</span></li>
                    <!-- <li><span class="dropdown-item">Section: A</span></li> -->
                </ul>
            </div>
            <!-- Hamburger Menu Button for Mobile View -->
            <button class="navbar-toggler ms-3" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
        </div>
    </header>

    <!-- Profile Section -->
    <div class="container">
        <div class="profile-container">
            <div class="profile-header">
                <!-- Profile Image Section (Moved to Left) -->
                <div class="profile-img-container">
                    <img id="profileImage" src="path_to_default_image.jpg" alt="Profile Picture">
                    <input type="file" id="fileInput" style="display: none;" accept="image/*">
                    <button onclick="document.getElementById('fileInput').click();">Add Photo</button>
                    <button onclick="removePhoto()">Remove Photo</button>
                </div>
                <h2>Manikandan Sir</h2>
                <p>Teacher Id: 12345 </p>
            </div>

            <div class="profile-info">
                <div class="info-box">
                    <h5>Student Details</h5>
                    <p><span class="info-title">Full Name:</span> Manikandan Sir</p>
                    <p><span class="info-title">Roll No:</span> 12345</p>
                    <p><span class="info-title">Date of Birth:</span> 01/01/2000</p>
                    <p><span class="info-title">Phone No:</span> +1234567890</p>
                    <p><span class="info-title">Enrollment No:</span> EN123456</p>
                    <p><span class="info-title">Course:</span> Computer Science</p>
                </div>

                <div class="info-box">
                    <h5>Contact Information</h5>
                    <p><span class="info-title">Email:</span> manikandansir@example.com</p>
                    <p><span class="info-title">Address:</span> 123 Main St, City, Country</p>
                    <p><span class="info-title">Emergency Contact:</span> +0987654321</p>
                </div>

                <div class="info-box">
                    <h5>Academic Information</h5>
                    <p><span class="info-title">Enrollment Date:</span> 2020-08-15</p>
                    <p><span class="info-title">Current Semester:</span> 4th Semester</p>
                    <p><span class="info-title">CGPA:</span> 8.5</p>
                </div>
            </div>

            <!-- Update Profile Button -->
            <div class="text-center mt-4">
                <button class="btn">Update Profile</button>
            </div>
        </div>
    </div>

    <!-- Footer Section -->
    <footer class="footer">
        <p>&copy; 2025 Institute ERP System. All rights reserved.</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Handle file input for profile image
        document.getElementById('fileInput').addEventListener('change', function(event) {
            const file = event.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('profileImage').src = e.target.result;
                };
                reader.readAsDataURL(file);
            }
        });

        // Function to remove photo
        function removePhoto() {
            document.getElementById('profileImage').src = 'path_to_default_image.jpg';
            document.getElementById('fileInput').value = '';  // Reset the file input
        }
    </script>
</body>

</html>
