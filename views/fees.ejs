<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fee Information</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Gilroy:wght@400;700&family=Juana:wght@400;700&display=swap');

        body {
            background: linear-gradient(to right, #0f0c29, #302b63, #24243e);
            color: white;
            font-family: 'Gilroy', sans-serif;
            transition: background 0.5s ease-in-out;
        }

        .footer {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 15px;
            color: white;
            text-align: center;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            position: fixed;
            bottom: 0;
            width: 100%;
        }

        .header {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 11px 30px 20px;
            color: white;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            font-family: 'Juana', serif;
            position: relative;
        }

        .header h1 {
            font-size: 2.6rem;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .header p {
            font-size: 1.2rem;
            margin-bottom: 20px;
            color: #d4d4d4;
        }

        .header nav {
            width: 60%;
        }

        .header .navbar-nav {
            display: flex;
            justify-content: center;
            width: 100%;
        }

        .header .navbar-nav .nav-item {
            padding: 10px 15px;
        }

        .header nav a {
            font-size: 1.1rem;
            font-weight: 600;
            color: white;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 5px;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .header nav a:hover {
            background-color: #ffffff33;
            color: #f9f9f9;
        }

        .header nav a.active {
            background-color: #ffffff66;
            color: #24243e;
            font-weight: 700;
        }

        .fees-section {
            max-width: 900px;
            margin: 50px auto 127px;
            padding: 30px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
            backdrop-filter: blur(10px);
        }

        .student-details {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .student-details img {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: 3px solid #24cfa6;
            object-fit: cover;
            transition: transform 0.3s ease-in-out;
        }

        .student-details img:hover {
            transform: scale(1.1);
        }

        .student-details .info {
            flex: 1;
            margin-left: 20px;
        }

        .student-details .info h3 {
            font-size: 1.8rem;
            margin-bottom: 10px;
        }

        .student-details .info p {
            font-size: 1.1rem;
            color: #d4d4d4;
        }

        .fee-info-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
        }

        .fee-info-table th, .fee-info-table td {
            padding: 12px 20px;
            text-align: left;
            border: 1px solid #ccc;
            color: white;
        }

        .fee-info-table th {
            background-color: #24cfa6;
        }

        .fee-info-table td {
            background-color: rgba(0, 0, 0, 0.1);
        }

        .payment-btn {
            width: 100%;
            padding: 15px;
            background-color: #24cfa6;
            color: white;
            font-size: 1.1rem;
            border-radius: 8px;
            cursor: pointer;
            border: none;
            transition: background-color 0.3s ease;
        }

        .payment-btn:hover {
            background-color: #1a9c7e;
        }

        /* Smooth page transitions */
        body {
            animation: fadeIn 1s ease-in-out;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        .upload-btn {
            margin-top: 20px;
            padding: 10px 20px;
            background-color: #24cfa6;
            color: white;
            border: none;
            font-size: 1.2rem;
            border-radius: 5px;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        .upload-btn:hover {
            background-color: #1a9c7e;
        }

        input[type="file"] {
            display: none;
        }
    </style>
</head>

<body>
    <!-- Header Section -->
    <header class="header d-flex justify-content-between align-items-center">
        <div>
            <h1>Welcome to the Student Panel</h1>
            <p>Your Fee Information</p>
        </div>
        <nav class="navbar navbar-expand-lg navbar-light w-60">
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto w-100 text-center">
                    <li class="nav-item">
                        <a href="/student_panel" class="nav-link ">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a href="/profile" class="nav-link">Profile</a>
                    </li>
                    <li class="nav-item">
                        <a href="/course" class="nav-link">Courses</a>
                    </li>
                    <li class="nav-item">
                        <a href="/fees" class="nav-link active">Fees</a>
                    </li>
                    <li class="nav-item">
                        <a href="/logout" class="nav-link">Logout</a>
                    </li>
                </ul>
            </div>
        </nav>
    </header>

    <!-- Fees Information Section -->
    <div class="fees-section">
        <div class="student-details">
            <img id="student-photo" src="https://cdn1.iconfinder.com/data/icons/circle-flats/170/contacts-512.png" alt="Student Photo">
            <div class="info">
                <h3>Anurag Kumar</h3>
                <p>Course: Computer Science</p>
                <p>Roll No: 12345</p>
                <!-- Upload photo button -->
                <label for="photo-upload" class="upload-btn">Upload Photo</label>
                <input type="file" id="photo-upload" accept="image/*" onchange="displayImage(event)">
            </div>
        </div>

        <h4>Fee Details</h4>
        <table class="fee-info-table">
            <thead>
                <tr>
                    <th>Subject</th>
                    <th>Total Fee</th>
                    <th>Amount Paid</th>
                    <th>Remaining Fee</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Mathematics</td>
                    <td>₹20,000</td>
                    <td>₹10,000</td>
                    <td>₹10,000</td>
                </tr>
                <tr>
                    <td>Computer Science</td>
                    <td>₹25,000</td>
                    <td>₹12,500</td>
                    <td>₹12,500</td>
                </tr>
                <tr>
                    <td>Physics</td>
                    <td>₹15,000</td>
                    <td>₹7,500</td>
                    <td>₹7,500</td>
                </tr>
            </tbody>
        </table>

        <h4>Total Fee Remaining: ₹30,000</h4>

        <!-- Payment button (can be linked to a payment gateway) -->
        <button class="payment-btn" onclick="payNow()">Proceed to Pay</button>
    </div>

    <!-- Footer Section -->
    <footer class="footer">
        <p>&copy; 2025 Institute ERP System. All rights reserved.</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Function to display selected student photo
        function displayImage(event) {
            var output = document.getElementById('student-photo');
            output.src = URL.createObjectURL(event.target.files[0]);
        }

        // Dummy function for "Proceed to Pay" (link to payment gateway here)
        function payNow() {
            alert('Redirecting to online payment...');
            // You can link this to a real payment gateway like PayPal, Stripe, etc.
        }
    </script>
</body>

</html>
