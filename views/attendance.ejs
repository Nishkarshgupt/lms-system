<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Attendance</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@3.10.2/dist/fullcalendar.min.css" />
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Gilroy:wght@400;700&family=Juana:wght@400;700&display=swap');

        body {
            background: linear-gradient(to right, #0f0c29, #302b63, #24243e);
            color: white;
            font-family: 'Gilroy', sans-serif;
            transition: background 0.5s ease-in-out;
        }

        .footer {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 15px;
            color: white;
            text-align: center;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            position: fixed;
            bottom: 0;
            width: 100%;
        }

        .header {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 11px 30px 20px;
            color: white;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            font-family: 'Juana', serif;
            position: relative;
        }

        .header h1 {
            font-size: 2.6rem;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .header p {
            font-size: 1.2rem;
            margin-bottom: 20px;
            color: #d4d4d4;
        }

        .header nav {
            width: 100%;
        }

        .header .navbar-nav {
            display: flex;
            justify-content: center;
            width: 100%;
        }

        .header .navbar-nav .nav-item {
            padding: 10px 15px;
        }

        .header nav a {
            font-size: 1.1rem;
            font-weight: 600;
            color: white;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 5px;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .header nav a:hover {
            background-color: #ffffff33;
            color: #f9f9f9;
        }

        .header nav a.active {
            background-color: #ffffff66;
            color: #24243e;
            font-weight: 700;
        }

        .calendar-section {
            margin: 6px auto;
            background: rgba(255, 255, 255, 0.1);
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
            backdrop-filter: blur(10px);
        }

        .attendance-table {
            margin: 40px auto 127px;
            background: rgba(255, 255, 255, 0.1);
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
            backdrop-filter: blur(10px);
        }

        .table th, .table td {
            text-align: center;
        }

        .btn {
            padding: 10px 20px;
            font-size: 1.1rem;
            border-radius: 8px;
            background-color: #24cfa6;
            color: white;
            transition: background-color 0.3s ease;
        }

        .btn:hover {
            background-color: #1a9c7e;
        }

        .attendance-icon {
            font-size: 16px;
            padding: 5px;
            border-radius: 50%;
        }

        .present {
            color: #28a745;
            background-color: #d4edda;
        }

        .absent {
            color: #dc3545;
            background-color: #f8d7da;
        }

        /* Smooth page transitions */
        body {
            animation: fadeIn 1s ease-in-out;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }
    </style>
</head>

<body>
    <!-- Header Section -->
    <header class="header d-flex justify-content-between align-items-center">
        <div>
            <h1>Welcome to the Attendance Portal</h1>
            <p>Check your attendance records</p>
        </div>
        <nav class="navbar navbar-expand-lg navbar-light w-100">
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto w-100 text-center">
                    <li class="nav-item">
                        <a href="/student_panel" class="nav-link">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a href="/profile" class="nav-link">Profile</a>
                    </li>
                    <li class="nav-item">
                        <a href="/course" class="nav-link">Courses</a>
                    </li>
                    <li class="nav-item">
                        <a href="/alumniconnect" class="nav-link">Alumni Connect</a>
                    </li>
                    <li class="nav-item">
                        <a href="/logout" class="nav-link">Logout</a>
                    </li>
                </ul>
            </div>
        </nav>
    </header>

    <!-- Calendar Section -->
    <div class="calendar-section">
        <h3 class="text-center mb-3">Select a Date to Check Attendance</h3>
        <div id="calendar"></div>
    </div>

    <!-- Attendance Table Section -->
    <div class="attendance-table">
        <h3 class="text-center mb-4">Attendance for January 2025</h3>
        <table class="table table-bordered text-white">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>01-01-2025</td>
                    <td><span class="attendance-icon present"><i class="fas fa-check"></i> P</span></td>
                </tr>
                <tr>
                    <td>02-01-2025</td>
                    <td><span class="attendance-icon absent"><i class="fas fa-times"></i> A</span></td>
                </tr>
                <tr>
                    <td>03-01-2025</td>
                    <td><span class="attendance-icon present"><i class="fas fa-check"></i> P</span></td>
                </tr>
                <tr>
                    <td>04-01-2025</td>
                    <td><span class="attendance-icon absent"><i class="fas fa-times"></i> A</span></td>
                </tr>
                <tr>
                    <td>05-01-2025</td>
                    <td><span class="attendance-icon present"><i class="fas fa-check"></i> P</span></td>
                </tr>
                <tr>
                    <td>06-01-2025</td>
                    <td><span class="attendance-icon absent"><i class="fas fa-times"></i> A</span></td>
                </tr>
                <tr>
                    <td>07-01-2025</td>
                    <td><span class="attendance-icon present"><i class="fas fa-check"></i> P</span></td>
                </tr>
                <tr>
                    <td>08-01-2025</td>
                    <td><span class="attendance-icon absent"><i class="fas fa-times"></i> A</span></td>
                </tr>
                <tr>
                    <td>09-01-2025</td>
                    <td><span class="attendance-icon present"><i class="fas fa-check"></i> P</span></td>
                </tr>
                <tr>
                    <td>10-01-2025</td>
                    <td><span class="attendance-icon absent"><i class="fas fa-times"></i> A</span></td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Footer Section -->
    <footer class="footer">
        <p>&copy; 2025 Institute ERP System. All rights reserved.</p>
    </footer>

    <!-- Bootstrap JS & FullCalendar JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/moment@2.29.1/moment.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@3.10.2/dist/fullcalendar.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#calendar').fullCalendar({
                events: [
                    {
                        title: 'P',
                        start: '2025-01-01',
                        color: '#28a745'
                    },
                    {
                        title: 'A',
                        start: '2025-01-02',
                        color: '#dc3545'
                    },
                    {
                        title: 'P',
                        start: '2025-01-03',
                        color: '#28a745'
                    },
                    {
                        title: 'A',
                        start: '2025-01-04',
                        color: '#dc3545'
                    },
                    {
                        title: 'P',
                        start: '2025-01-05',
                        color: '#28a745'
                    },
                    {
                        title: 'A',
                        start: '2025-01-06',
                        color: '#dc3545'
                    },
                    {
                        title: 'P',
                        start: '2025-01-07',
                        color: '#28a745'
                    },
                    {
                        title: 'A',
                        start: '2025-01-08',
                        color: '#dc3545'
                    },
                    {
                        title: 'P',
                        start: '2025-01-09',
                        color: '#28a745'
                    },
                    {
                        title: 'A',
                        start: '2025-01-10',
                        color: '#dc3545'
                    }
                ],
                dayClick: function(date) {
                    alert('You clicked on ' + date.format());
                }
            });
        });
    </script>
</body>

</html>
