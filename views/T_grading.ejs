<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Grading Management</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Gilroy:wght@400;700&family=Juana:wght@400;700&display=swap');

        body {
            background: linear-gradient(to right, #0f0c29, #302b63, #24243e);
            color: white;
            font-family: 'Gilroy', sans-serif;
            transition: background 0.5s ease-in-out;
        }

        .footer {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 15px;
            color: white;
            text-align: center;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            position: fixed;
            bottom: 0;
            width: 100%;
        }

        .header {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 11px 30px 20px;
            color: white;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            font-family: 'Juana', serif;
            position: relative;
        }

        .header h1 {
            font-size: 2.6rem;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .header p {
            font-size: 1.2rem;
            margin-bottom: 20px;
            color: #d4d4d4;
        }

        .header nav {
            width: 100%;
        }

        .header .navbar-nav {
            display: flex;
            justify-content: center;
            width: 100%;
        }

        .header .navbar-nav .nav-item {
            padding: 10px 15px;
        }

        .header nav a {
            font-size: 1.1rem;
            font-weight: 600;
            color: white;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 5px;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .header nav a:hover {
            background-color: #ffffff33;
            color: #f9f9f9;
        }

        .header nav a.active {
            background-color: #ffffff66;
            color: #24243e;
            font-weight: 700;
        }

        .grading-container {
            max-width: 1200px;
            margin: 50px auto;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
            backdrop-filter: blur(10px);
        }

        .grading-table {
            width: 100%;
            margin-top: 30px;
            border-collapse: collapse;
        }

        .grading-table th, .grading-table td {
            padding: 10px;
            text-align: center;
            border: 1px solid #ddd;
        }

        .grading-table th {
            background-color: #24cfa6;
            color: white;
        }

        .grading-table td {
            background-color: #1e1e2f;
            color: white;
        }

        .btn {
            padding: 10px 20px;
            font-size: 1.1rem;
            border-radius: 8px;
            background-color: #24cfa6;
            color: white;
            transition: background-color 0.3s ease;
        }

        .btn:hover {
            background-color: #1a9c7e;
        }

        .dropdown {
            margin-top: 20px;
        }

        .grading-table select {
            background-color: #1e1e2f;
            border: none;
            padding: 5px;
            color: white;
        }
    </style>
</head>

<body>
    <!-- Header Section -->
    <header class="header d-flex justify-content-between align-items-center">
        <div>
            <h1>Welcome to the Teacher Panel</h1>
            <p>Grade Students Effectively</p>
        </div>
        <nav class="navbar navbar-expand-lg navbar-light w-100">
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto w-100 text-center">
                    <li class="nav-item">
                        <a href="/teacher_panel" class="nav-link">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a href="/T_profile" class="nav-link">Profile</a>
                    </li>
                   
                    <li class="nav-item">
                        <a href="/T_attendance" class="nav-link">Attendance</a>
                    </li>
                    <li class="nav-item">
                        <a href="/T_grading" class="nav-link active">Grading</a>
                    </li>
                    <li class="nav-item">
                        <a href="/logout" class="nav-link">Logout</a>
                    </li>
                </ul>
            </div>
        </nav>
    </header>

    <!-- Main Section (Grading) -->
    <div class="grading-container">
        <h2 class="text-center mb-4">Grade Your Students</h2>

        <!-- Grading Table -->
        <table class="grading-table">
            <thead>
                <tr>
                    <th>Student Name</th>
                    <th>Grade</th>
                    <th>Update Grade</th>
                </tr>
            </thead>
            <tbody>
                <!-- Example student list with grades -->
                <tr>
                    <td>Anurag</td>
                    <td>
                        <select>
                            <option value="A+">A+</option>
                            <option value="A">A</option>
                            <option value="B">B</option>
                            <option value="B+">B+</option>
                            <option value="C">C</option>
                        </select>
                    </td>
                    <td><button class="btn">Update</button></td>
                </tr>
                <tr>
                    <td>Rajesh Kumar</td>
                    <td>
                        <select>
                            <option value="A+">A+</option>
                            <option value="A">A</option>
                            <option value="B">B</option>
                            <option value="B+">B+</option>
                            <option value="C">C</option>
                        </select>
                    </td>
                    <td><button class="btn">Update</button></td>
                </tr>
                <tr>
                    <td>Anjali Sharma</td>
                    <td>
                        <select>
                            <option value="A+">A+</option>
                            <option value="A">A</option>
                            <option value="B">B</option>
                            <option value="B+">B+</option>
                            <option value="C">C</option>
                        </select>
                    </td>
                    <td><button class="btn">Update</button></td>
                </tr>
                <!-- Add more students as needed -->
            </tbody>
        </table>
    </div>

    <!-- Footer Section -->
    <footer class="footer">
        <p>&copy; 2025 Institute ERP System. All rights reserved.</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
