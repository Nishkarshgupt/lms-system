<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teacher Exam Management</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Gilroy:wght@400;700&family=Juana:wght@400;700&display=swap');

        body {
            background: linear-gradient(to right, #0f0c29, #302b63, #24243e);
            color: white;
            font-family: 'Gilroy', sans-serif;
            transition: background 0.5s ease-in-out;
        }

        .footer {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 15px;
            color: white;
            text-align: center;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            position: fixed;
            bottom: 0;
            width: 100%;
        }

        .header {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 11px 30px 20px;
            color: white;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            font-family: 'Juana', serif;
            position: relative;
        }

        .header h1 {
            font-size: 2.6rem;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .header p {
            font-size: 1.2rem;
            margin-bottom: 20px;
            color: #d4d4d4;
        }

        .header nav {
            width: 100%;
        }

        .header .navbar-nav {
            display: flex;
            justify-content: center;
            width: 100%;
        }

        .header .navbar-nav .nav-item {
            padding: 10px 15px;
        }

        .header nav a {
            font-size: 1.1rem;
            font-weight: 600;
            color: white;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 5px;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .header nav a:hover {
            background-color: #ffffff33;
            color: #f9f9f9;
        }

        .header nav a.active {
            background-color: #ffffff66;
            color: #24243e;
            font-weight: 700;
        }

        .btn {
            padding: 10px 20px;
            font-size: 1.1rem;
            border-radius: 8px;
            background-color: #24cfa6;
            color: white;
            transition: background-color 0.3s ease;
        }

        .btn:hover {
            background-color: #1a9c7e;
        }

        .exam-container {
            max-width: 1000px;
            margin: 50px auto;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
            backdrop-filter: blur(10px);
        }

        .exam-container h2 {
            text-align: center;
            margin-bottom: 30px;
        }

        .exam-form input,
        .exam-form select,
        .exam-form textarea {
            background-color: #1e1e2f;
            border: none;
            padding: 10px;
            color: white;
            border-radius: 8px;
            width: 100%;
            margin-bottom: 15px;
        }

        .exam-form button {
            background-color: #24cfa6;
            color: white;
            padding: 12px 20px;
            border-radius: 8px;
            width: 100%;
            border: none;
            transition: background-color 0.3s ease;
        }

        .exam-form button:hover {
            background-color: #1a9c7e;
        }

        .exam-schedule-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 30px;
        }

        .exam-schedule-table th,
        .exam-schedule-table td {
            padding: 12px;
            text-align: center;
            border: 1px solid #444;
        }

        .exam-schedule-table th {
            background-color: #302b63;
        }

        .exam-schedule-table td {
            background-color: #24243e;
        }

        .exam-schedule-table tr:hover {
            background-color: #333;
        }

        .exam-card {
            background-color: #1e1e2f;
            padding: 20px;
            margin: 15px 0;
            border-radius: 8px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
        }

        .exam-card .exam-title {
            font-size: 1.5rem;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .exam-card .exam-details {
            font-size: 1.1rem;
            margin-bottom: 15px;
        }

        .exam-card .exam-date {
            font-size: 1.1rem;
            color: #ffb86c;
        }

        .exam-card .exam-button {
            background-color: #e74c3c;
            border: none;
            color: white;
            padding: 10px;
            border-radius: 8px;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        .exam-card .exam-button:hover {
            background-color: #c0392b;
        }
    </style>
</head>

<body>
    <!-- Header Section -->
    <header class="header d-flex justify-content-between align-items-center">
        <div>
            <h1>Welcome to the Teacher Panel</h1>
            <p>Exam Management</p>
        </div>
        <nav class="navbar navbar-expand-lg navbar-light w-100">
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto w-100 text-center">
                    <li class="nav-item">
                        <a href="/teacher_panel" class="nav-link">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a href="/T_profile" class="nav-link">Profile</a>
                    </li>
                    
                    <li class="nav-item">
                        <a href="/T_attendance" class="nav-link">Attendance</a>
                    </li>
                    <li class="nav-item">
                        <a href="/T_logout" class="nav-link">Logout</a>
                    </li>
                </ul>
            </div>
        </nav>
    </header>

    <!-- Main Section (Exam Management) -->
    <div class="exam-container">
        <h2>Manage Exams</h2>

        <!-- Form to Create a New Exam -->
        <div class="exam-form">
            <h4>Create New Exam</h4>
            <input type="text" id="exam-title" placeholder="Exam Title" required>
            <input type="date" id="exam-date" required>
            <select id="exam-subject" required>
                <option value="">Select Subject</option>
                <!-- BTech CSE Subjects -->
                <option value="Data Structures">Data Structures</option>
                <option value="Algorithms">Algorithms</option>
                <option value="Discrete Mathematics">Discrete Mathematics</option>
                <option value="Operating Systems">Operating Systems</option>
                <option value="Database Management Systems">Database Management Systems</option>
                <option value="Computer Networks">Computer Networks</option>
                <option value="Software Engineering">Software Engineering</option>
                <option value="Digital Logic Design">Digital Logic Design</option>
                <option value="Compiler Design">Compiler Design</option>
                <option value="Artificial Intelligence">Artificial Intelligence</option>
                <option value="Machine Learning">Machine Learning</option>
            </select>
            <textarea id="exam-description" placeholder="Exam Description" rows="4" required></textarea>
            <button type="button" onclick="createExam()">Create Exam</button>
        </div>

        <!-- Scheduled Exams List -->
        <div>
            <h4>Scheduled Exams</h4>
            <table class="exam-schedule-table">
                <thead>
                    <tr>
                        <th>Exam Title</th>
                        <th>Subject</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="exam-schedule-body">
                    <!-- Exam rows will appear here -->
                </tbody>
            </table>
        </div>
    </div>

    <!-- Footer Section -->
    <footer class="footer">
        <p>&copy; 2025 Institute ERP System. All rights reserved.</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        let examList = [];

        function createExam() {
            const title = document.getElementById("exam-title").value;
            const date = document.getElementById("exam-date").value;
            const subject = document.getElementById("exam-subject").value;
            const description = document.getElementById("exam-description").value;

            if (title && date && subject && description) {
                const exam = {
                    title,
                    date,
                    subject,
                    description
                };

                examList.push(exam);
                updateExamSchedule();
                clearForm();
            } else {
                alert("Please fill all fields.");
            }
        }

        function updateExamSchedule() {
            const examScheduleBody = document.getElementById("exam-schedule-body");
            examScheduleBody.innerHTML = '';

            examList.forEach((exam, index) => {
                const row = document.createElement("tr");
                row.innerHTML = `
                    <td>${exam.title}</td>
                    <td>${exam.subject}</td>
                    <td>${exam.date}</td>
                    <td>
                        <button class="exam-button" onclick="deleteExam(${index})">Delete</button>
                    </td>
                `;
                examScheduleBody.appendChild(row);
            });
        }

        function deleteExam(index) {
            examList.splice(index, 1);
            updateExamSchedule();
        }

        function clearForm() {
            document.getElementById("exam-title").value = '';
            document.getElementById("exam-date").value = '';
            document.getElementById("exam-subject").value = '';
            document.getElementById("exam-description").value = '';
        }
    </script>
</body>

</html>
