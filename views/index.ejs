<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Gilroy:wght@400;700&family=Juana:wght@400;700&display=swap');

        body {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background: linear-gradient(to right, #0f0c29, #302b63, #24243e);
            color: white;
            font-family: 'Gilroy', sans-serif;
            margin: 0;
        }

        .start-btn-container {
            text-align: center;
        }

        .start-btn {
            background-color: #24cfa6;
            border: none;
            padding: 30px;
            border-radius: 50%; /* Circular shape */
            font-size: 3rem;
            color: white;
            cursor: pointer;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
            transition: background-color 0.3s, transform 0.3s;
        }

        .start-btn:hover {
            background-color: #2d7a2f;
            transform: scale(1.1); /* Slightly larger on hover */
        }

        .option-buttons {
            display: none;
            margin-top: 30px;
            text-align: center;
        }
        
        .option-card {
            cursor: pointer;
            background-color: rgba(255, 255, 255, 0.2);
            border-radius: 15px;
            padding: 25px;
            margin: 15px;
            width: 250px;
            display: inline-block;
            text-align: center;
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .option-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.2);
        }

        .option-card i {
            font-size: 3rem;
            color: white;
            margin-bottom: 15px;
        }

        .option-card h4 {
            font-size: 1.5rem;
            color: white;
        }

        .footer {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 1rem;
        }

        .footer a {
            color: #24cfa6;
        }

        .footer a:hover {
            text-decoration: underline;
        }

    </style>
</head>

<body>

    <div class="start-btn-container">
        <button class="start-btn" id="startBtn">Start</button>

        <!-- Option Cards -->
        <div class="option-buttons" id="optionBtns">
            <div class="option-card" id="studentCard">
                <i class="fas fa-user-graduate"></i>
                <h4>Student</h4>
            </div>
            <div class="option-card" id="teacherCard">
                <i class="fas fa-chalkboard-teacher"></i>
                <h4>Teacher</h4>
            </div>
        </div>
    </div>

    <div class="footer">
        <p>&copy; 2025 Institute ERP System. <a href="#">Terms & Conditions</a></p>
    </div>

    <!-- Bootstrap JS, Popper.js -->
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.6/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.min.js"></script>

    <script>
        // Show the options when Start button is clicked
        document.getElementById('startBtn').addEventListener('click', function () {
            document.getElementById('startBtn').style.display = 'none'; // Hide Start button
            document.getElementById('optionBtns').style.display = 'block'; // Show options
        });

        // Redirect to Student Login
        document.getElementById('studentCard').addEventListener('click', function () {
            window.location.href = "/student_load"; 
             
        });

        // Redirect to Teacher Login
        document.getElementById('teacherCard').addEventListener('click', function () {
            window.location.href = '/teacher_load'; 
        });
    </script>

</body>

</html>
