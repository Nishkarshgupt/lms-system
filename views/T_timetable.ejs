            </div>
            <div class="class-info">
                <p><span class="time">2:15 PM - 3:45 PM</span> <br>Class: Data Mining</p>
                <p>Classroom: D5</p>
            </div>
            <div class="class-info">
                <p><span class="time">4:00 PM - 5:30 PM</span> <br>Class: Cloud Computing</p>
                <p>Classroom: E6</p>
            </div>
        </div>

        <!-- Wednesday -->
        <div class="day-card">
            <h4>Wednesday</h4>
            <div class="class-info">
                <p><span class="time">9:00 AM - 10:30 AM</span> <br>Class: Software Testing</p>
                <p>Classroom: F1</p>
            </div>
            <div class="class-info">
                <p><span class="time">10:45 AM - 12:15 PM</span> <br>Class: Mobile App Development</p>
                <p>Classroom: G2</p>
            </div>
            <div class="class-info">
                <p><span class="time">12:30 PM - 2:00 PM</span> <br>Class: Internet of Things</p>
                <p>Classroom: H3</p>
            </div>
            <div class="class-info">
                <p><span class="time">2:15 PM - 3:45 PM</span> <br>Class: Cyber Security</p>
                <p>Classroom: I4</p>
            </div>
            <div class="class-info">
                <p><span class="time">4:00 PM - 5:30 PM</span> <br>Class: Human Computer Interaction</p>
                <p>Classroom: J5</p>
            </div>
        </div>

        <!-- Add additional days as needed -->
    </div>

    <!-- Footer Section -->
    <footer class="footer">
        <p>&copy; 2025 Institute ERP System. All rights reserved.</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
