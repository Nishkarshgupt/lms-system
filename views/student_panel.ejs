                        <h5 class="mt-3">Courses</h5>
                        <a href="/course" class="btn btn-success mt-2">Open</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="box shadow-sm">
                    <div class="box-body">
                        <i class="fas fa-chair text-pink"></i>
                        <h5 class="mt-3">Examination Seating Plan</h5>
                        <a href="/examination_seating_plan" class="btn btn-warning mt-2">Open</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="box shadow-sm">
                    <div class="box-body">
                        <i class="fas fa-file-alt text-indigo"></i>
                        <h5 class="mt-3">Fee Undertaking</h5>
                        <a href="/fee_undertaking" class="btn btn-primary mt-2">Open</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="box shadow-sm">
                    <div class="box-body">
                        <i class="fas fa-comments text-cyan"></i>
                        <h5 class="mt-3">Feedback</h5>
                        <a href="/feedback" class="btn btn-success mt-2">Open</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="box shadow-sm">
                    <div class="box-body">
                        <i class="fas fa-wallet text-orange"></i>
                        <h5 class="mt-3">Fees</h5>
                        <a href="/fees" class="btn btn-warning mt-2">Open</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="box shadow-sm">
                    <div class="box-body">
                        <i class="fas fa-book-open text-lime"></i>
