    <script>
        // DOM fully load hone par yeh code chalega
        window.addEventListener('DOMContentLoaded', () => {
            // LocalStorage se user data fetch karenge
            const user = JSON.parse(localStorage.getItem('user'));

            // Agar user data exist karta hai, to dropdown ko update karenge
            if (user) {
                const nameElement = document.querySelector('.dropdown-item.name');
                const rollNoElement = document.querySelector('.dropdown-item.rollNo');
                const sectionElement = document.querySelector('.dropdown-item.section');

                // Dropdown ke items ko update karenge
                if (nameElement) nameElement.textContent = `Name: ${user.name}`;
                if (rollNoElement) rollNoElement.textContent = `Roll No: ${user.rollNo}`;
                if (sectionElement) sectionElement.textContent = `Section: ${user.section}`;
            } else {
                console.log("User data nahi mil raha hai.");
            }
        });

    </script>




</body>

</html>