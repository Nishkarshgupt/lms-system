                        <a href="/lms" class="btn btn-primary mt-2">Open</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="box shadow-sm">
                    <div class="box-body">
                        <i class="fas fa-users text-brown"></i>
                        <h5 class="mt-3">Mentor Mentee</h5>
                        <a href="/mentor_mentee" class="btn btn-success mt-2">Open</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="box shadow-sm">
                    <div class="box-body">
                        <i class="fas fa-file-alt text-purple"></i>
                        <h5 class="mt-3">My Report Card</h5>
                        <a href="/my_report_card" class="btn btn-warning mt-2">Open</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="box shadow-sm">
                    <div class="box-body">
                        <i class="fas fa-video text-success"></i> <!-- Video calling icon -->
                        <h5 class="mt-3">Video Calling</h5>
                        <a href="/video_calling" class="btn btn-success mt-2">Start Call</a>
                        <!-- Button to start video call -->
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="box shadow-sm">
                    <div class="box-body">
                        <i class="fas fa-briefcase text-primary"></i> <!-- Placement Coordinator icon -->
                        <h5 class="mt-3">Placement Coordinator</h5>
                        <a href="/placement_coordinator" class="btn btn-primary mt-2">Contact</a>
                        <!-- Button for contacting -->
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="box shadow-sm">
                    <div class="box-body">
                        <i class="fas fa-book text-warning"></i> <!-- Library Books icon -->
                        <h5 class="mt-3">Library Books (PDF)</h5>
                        <a href="/library_books" class="btn btn-warning mt-2">Download</a>
                        <!-- Button to download PDF -->
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="box shadow-sm">
                    <div class="box-body">
                        <i class="fas fa-envelope text-danger"></i> <!-- Messaging icon -->
                        <h5 class="mt-3">Message Registrar Office</h5>
                        <a href="/message_registrar" class="btn btn-danger mt-2">Send Message</a>
                        <!-- Button for messaging -->
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="box shadow-sm">
                    <div class="box-body">
                        <i class="fas fa-comment-dots text-info"></i> <!-- Chatbot icon -->
                        <h5 class="mt-3">Chatbot</h5>
                        <a href="/chatbot" class="btn btn-info mt-2">Talk to Bot</a> <!-- Button to open chatbot -->
                    </div>
                </div>
            </div>

        </div>
    </main>

    <!-- Footer Section -->
    <footer class="footer">
        <p>&copy; 2025 Institute ERP System. All rights reserved.</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>



