<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Notifications</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Gilroy:wght@400;700&family=Juana:wght@400;700&display=swap');

        body {
            background: linear-gradient(to right, #0f0c29, #302b63, #24243e);
            color: white;
            font-family: 'Gilroy', sans-serif;
            transition: background 0.5s ease-in-out;
        }

        .footer {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 15px;
            color: white;
            text-align: center;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            position: fixed;
            bottom: 0;
            width: 100%;
        }

        .header {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 11px 30px 20px;
            color: white;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            font-family: 'Juana', serif;
            position: relative;
        }

        .header h1 {
            font-size: 2.6rem;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .header p {
            font-size: 1.2rem;
            margin-bottom: 20px;
            color: #d4d4d4;
        }

        .header nav {
            width: 100%;
        }

        .header .navbar-nav {
            display: flex;
            justify-content: center;
            width: 100%;
        }

        .header .navbar-nav .nav-item {
            padding: 10px 15px;
        }

        .header nav a {
            font-size: 1.1rem;
            font-weight: 600;
            color: white;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 5px;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .header nav a:hover {
            background-color: #ffffff33;
            color: #f9f9f9;
        }

        .header nav a.active {
            background-color: #ffffff66;
            color: #24243e;
            font-weight: 700;
        }

        .btn {
            padding: 10px 20px;
            font-size: 1.1rem;
            border-radius: 8px;
            background-color: #24cfa6;
            color: white;
            transition: background-color 0.3s ease;
        }

        .btn:hover {
            background-color: #1a9c7e;
        }

        /* Main section styles */
        .notifications-container {
            max-width: 1200px;
            margin: 50px auto;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
            backdrop-filter: blur(10px);
        }

        .notification-card {
            background: rgba(255, 255, 255, 0.2);
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 20px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease;
        }

        .notification-card:hover {
            transform: translateY(-5px);
        }

        .notification-title {
            font-size: 1.2rem;
            font-weight: bold;
        }

        .notification-details {
            font-size: 1rem;
            margin-top: 10px;
            color: #d4d4d4;
        }

        @media (max-width: 768px) {
            .profile-info {
                flex-direction: column;
            }

            .profile-info .info-box {
                width: 100%;
            }
        }

        /* Smooth page transitions */
        body {
            animation: fadeIn 1s ease-in-out;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }
    </style>
</head>

<body>
    <!-- Header Section -->
    <header class="header d-flex justify-content-between align-items-center">
        <div>
            <h1>Welcome to the Student Panel</h1>
            <p>Manage your academic activities</p>
        </div>
        <nav class="navbar navbar-expand-lg navbar-light w-100">
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto w-100 text-center">
                    <li class="nav-item">
                        <a href="/student_panel" class="nav-link ">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a href="/profile" class="nav-link">Profile</a>
                    </li>
                    <li class="nav-item">
                        <a href="/course" class="nav-link">Courses</a>
                    </li>
                    <li class="nav-item">
                        <a href="/notification" class="nav-link active">Notifications</a>
                    </li>
                    <li class="nav-item">
                        <a href="/logout" class="nav-link">Logout</a>
                    </li>
                </ul>
            </div>
        </nav>
        <div class="d-flex align-items-end justify-content-end">
            <!-- Profile Dropdown -->
            <div class="dropdown me-3">
                <button class="btn btn-outline-light dropdown-toggle" type="button" id="profileDropdown"
                    data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="fas fa-user"></i> Profile
                </button>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="profileDropdown">
                    <li><span class="dropdown-item">Name: Anurag Kumar</span></li>
                    <li><span class="dropdown-item">Roll No: 12345</span></li>
                    <li><span class="dropdown-item">Section: A</span></li>
                </ul>
            </div>
            <!-- Hamburger Menu Button for Mobile View -->
            <button class="navbar-toggler ms-3" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
        </div>
    </header>

    <!-- Main Section (Notifications) -->
    <div class="notifications-container">
        <h2 class="text-center mb-4">Your Notifications</h2>

        <!-- Notification Cards -->
        <a href="/frontend/student_features/notification_detail.html" class="text-decoration-none">
            <div class="notification-card">
                <div class="notification-title">Course Update</div>
                <div class="notification-details">Your "Mathematics" course has a new assignment available. Please check the LMS for details.</div>
            </div>
        </a>

        <a href="/frontend/student_features/notification_detail.html" class="text-decoration-none">
            <div class="notification-card">
                <div class="notification-title">Attendance Alert</div>
                <div class="notification-details">Your attendance for "Physics" is 10% below the required limit. Please attend more classes.</div>
            </div>
        </a>

        <a href="/frontend/student_features/notification_detail.html" class="text-decoration-none">
            <div class="notification-card">
                <div class="notification-title">Exam Schedule</div>
                <div class="notification-details">The final exam for "Chemistry" is scheduled for the 25th of January, 2025. Prepare accordingly.</div>
            </div>
        </a>

        <a href="/frontend/student_features/notification_detail.html" class="text-decoration-none">
            <div class="notification-card">
                <div class="notification-title">Class Timetable</div>
                <div class="notification-details">Your "Computer Science" class has been rescheduled to 2:00 PM on weekdays starting from next week.</div>
            </div>
        </a>

        <a href="/frontend/student_features/notification_detail.html" class="text-decoration-none">
            <div class="notification-card">
                <div class="notification-title">Upcoming Seminar</div>
                <div class="notification-details">There will be a seminar on "AI and Robotics" this Friday at 3:00 PM in the auditorium. Don't miss it!</div>
            </div>
        </a>
    </div>

    <!-- Footer Section -->
    <footer class="footer">
        <p>&copy; 2025 Institute ERP System. All rights reserved.</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
