<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teacher Mentor</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Gilroy:wght@400;700&family=Juana:wght@400;700&display=swap');

        body {
            background: linear-gradient(to right, #0f0c29, #302b63, #24243e);
            color: white;
            font-family: 'Gilroy', sans-serif;
            transition: background 0.5s ease-in-out;
        }

        .footer {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 15px;
            color: white;
            text-align: center;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            position: fixed;
            bottom: 0;
            width: 100%;
        }

        .header {
            background: linear-gradient(45deg, #24cfa6, #302b63);
            padding: 11px 30px 20px;
            color: white;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            font-family: 'Juana', serif;
            position: relative;
        }

        .header h1 {
            font-size: 2.6rem;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .header p {
            font-size: 1.2rem;
            margin-bottom: 20px;
            color: #d4d4d4;
        }

        .header nav {
            width: 100%;
        }

        .header .navbar-nav {
            display: flex;
            justify-content: center;
            width: 100%;
        }

        .header .navbar-nav .nav-item {
            padding: 10px 15px;
        }

        .header nav a {
            font-size: 1.1rem;
            font-weight: 600;
            color: white;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 5px;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .header nav a:hover {
            background-color: #ffffff33;
            color: #f9f9f9;
        }

        .header nav a.active {
            background-color: #ffffff66;
            color: #24243e;
            font-weight: 700;
        }

        .btn {
            padding: 10px 20px;
            font-size: 1.1rem;
            border-radius: 8px;
            background-color: #24cfa6;
            color: white;
            transition: background-color 0.3s ease;
        }

        .btn:hover {
            background-color: #1a9c7e;
        }

        .mentor-container {
            max-width: 1000px;
            margin: 50px auto 172px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
            backdrop-filter: blur(10px);
        }

        .mentor-container h2 {
            text-align: center;
            margin-bottom: 30px;
        }

        .student-card {
            background-color: #1e1e2f;
            margin: 15px 0;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.3);
            transition: transform 0.3s ease-in-out, box-shadow 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .student-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        }

        .student-card img {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            margin-left: 20px;
        }

        .student-card .info {
            flex-grow: 1;
        }

        .student-card h5 {
            font-size: 1.6rem;
            margin-bottom: 10px;
        }

        .student-card p {
            font-size: 1.2rem;
        }

        .student-card .btn-message {
            margin-top: 10px;
        }
    </style>
</head>

<body>
    <!-- Header Section -->
    <header class="header d-flex justify-content-between align-items-center">
        <div>
            <h1>Welcome to the Teacher Panel</h1>
            <p>Your Mentoring List</p>
        </div>
        <nav class="navbar navbar-expand-lg navbar-light w-100">
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto w-100 text-center">
                    <li class="nav-item">
                        <a href="/teacher_panel" class="nav-link">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a href="/T_profile" class="nav-link">Profile</a>
                    </li>
                    
                    <li class="nav-item">
                        <a href="/T_attendance" class="nav-link">Attendance</a>
                    </li>
                    <li class="nav-item">
                        <a href="/logout" class="nav-link">Logout</a>
                    </li>
                </ul>
            </div>
        </nav>
        <div class="d-flex align-items-end justify-content-end">
            <!-- Profile Dropdown -->
            <div class="dropdown me-3">
                <button class="btn btn-outline-light dropdown-toggle" type="button" id="profileDropdown"
                    data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="fas fa-user"></i> Profile
                </button>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="profileDropdown">
                    <li><span class="dropdown-item">Name: Manikandan sir</span></li>
                    <li><span class="dropdown-item">Teacher ID: T12345</span></li>
                    <li><span class="dropdown-item">Department: Computer Science</span></li>
                </ul>
            </div>
        </div>
    </header>

    <!-- Main Section (Mentor List) -->
    <div class="mentor-container">
        <h2>Your Students List</h2>

        <!-- Student 1 -->
        <div class="student-card">
            <div class="info">
                <h5>Student Name: Rahul Kumar</h5>
                <p>Student ID: S12345</p>
                <p>Email: rahul.kumar@student.com</p>
                <p>Course: Computer Science</p>
                <p>Batch: A</p>
                <button class="btn btn-message" onclick="sendMessage('Rahul Kumar')">Send Message</button>
            </div>
            <img src="https://via.placeholder.com/70" alt="Rahul Kumar">
        </div>

        <!-- Student 2 -->
        <div class="student-card">
            <div class="info">
                <h5>Student Name: Priya Sharma</h5>
                <p>Student ID: S12346</p>
                <p>Email: priya.sharma@student.com</p>
                <p>Course: Computer Science</p>
                <p>Batch: B</p>
                <button class="btn btn-message" onclick="sendMessage('Priya Sharma')">Send Message</button>
            </div>
            <img src="https://via.placeholder.com/70" alt="Priya Sharma">
        </div>

        <!-- Student 3 -->
        <div class="student-card">
            <div class="info">
                <h5>Student Name: Arjun Singh</h5>
                <p>Student ID: S12347</p>
                <p>Email: arjun.singh@student.com</p>
                <p>Course: Computer Science</p>
                <p>Batch: C</p>
                <button class="btn btn-message" onclick="sendMessage('Arjun Singh')">Send Message</button>
            </div>
            <img src="https://via.placeholder.com/70" alt="Arjun Singh">
        </div>

        <!-- Add more students as needed -->
    </div>

    <!-- Footer Section -->
    <footer class="footer">
        <p>&copy; 2025 Institute ERP System. All rights reserved.</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Function to simulate sending a message
        function sendMessage(studentName) {
            alert('Message sent to ' + studentName);
        }
    </script>
</body>

</html>
